{
  "name": "tb-order-sync",
  "version": "0.4.6",
  "description": "Tencent Docs order sync CLI with one-command npm install, gross-profit automation, refund marking, self-check, and daemon mode",
  "bin": {
    "tb": "bin/tb.js"
  },
  "files": [
    "bin/",
    "cli/**/*.py",
    "config/**/*.py",
    "connectors/**/*.py",
    "models/**/*.py",
    "services/**/*.py",
    "utils/**/*.py",
    "main.py",
    "requirements.txt",
    "README.md",
    "快速开始.txt",
    "CHANGELOG.md",
    "LICENSE",
    ".env.example",
    "build.py",
    "sync_service.spec",
    "启动.bat",
    "启动.command"
  ],
  "scripts": {
    "postinstall": "node bin/postinstall.js",
    "tb": "node bin/tb.js",
    "check": "node bin/tb.js check",
    "pack:local": "npm pack"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SOULRAi/tb-order-sync.git"
  },
  "homepage": "https://github.com/SOULRAi/tb-order-sync#readme",
  "bugs": {
    "url": "https://github.com/SOULRAi/tb-order-sync/issues"
  },
  "keywords": [
    "order-sync",
    "refund-workflow",
    "gross-profit",
    "daemon",
    "autostart",
    "self-check",
    "scheduler",
    "rich-cli",
    "tencent-docs",
    "feishu",
    "spreadsheet-sync",
    "automation"
  ],
  "license": "MIT"
}
